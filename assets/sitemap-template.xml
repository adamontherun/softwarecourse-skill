<?xml version="1.0" encoding="UTF-8"?>
<!--
  One <url> for the cover page plus one per chapter, generated at Deploy
  step 9 once {{PAGES_URL}} is known (the same pass that resolves every
  other deploy-time token) — don't hand-maintain N near-identical blocks.
  {{LASTMOD}} is today's date (YYYY-MM-DD) at deploy time; regenerate this
  file (don't hand-edit dates) if content changes later and you redeploy.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>{{PAGES_URL}}</loc>
    <lastmod>{{LASTMOD}}</lastmod>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>{{PAGES_URL}}chapters/ch{{CH_NUM_PADDED}}.html</loc>
    <lastmod>{{LASTMOD}}</lastmod>
    <priority>0.8</priority>
  </url>
</urlset>
